{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "MkDocs: Build",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/mkdocs",
      "args": [
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Site & TTS Audio",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PIPER_TTS_GENERATE_AUDIO": "true"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Publish Runtime Assets to GitHub",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "publish-runtime-assets"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "MkDocs: Deploy",
      "type": "shell",
      "command": "git",
      "args": [
        "push",
        "origin",
        "main"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "Build Site & TTS Audio",
        "Publish Runtime Assets to GitHub"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
